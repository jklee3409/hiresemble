# Docker Compose - PostgreSQL
POSTGRES_DB=hiresemble
POSTGRES_USER=hiresemble
POSTGRES_PASSWORD=hiresemble-local-password
POSTGRES_PORT=5432

# Backend datasource (JDBC URL)
DATABASE_URL=jdbc:postgresql://localhost:5432/hiresemble
DATABASE_USERNAME=hiresemble
DATABASE_PASSWORD=hiresemble-local-password
BACKEND_PORT=8080
SESSION_TIMEOUT=30m
SESSION_COOKIE_NAME=SESSION
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Idempotency HMAC (required for upload, manual-text, reparse, and retry mutations)
IDEMPOTENCY_HASH_KEY_VERSION=1
IDEMPOTENCY_HMAC_KEY=

# Docker Compose - MinIO / S3-compatible object storage
MINIO_ROOT_USER=hiresemble
MINIO_ROOT_PASSWORD=hiresemble-local-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=hiresemble
OBJECT_STORAGE_SECRET_KEY=hiresemble-local-secret
OBJECT_STORAGE_BUCKET=hiresemble
OBJECT_STORAGE_REGION=us-east-1

# Document parser, deletion worker, and versioned AI reservation estimate
DOCUMENT_PARSER_TIMEOUT=15s
DOCUMENT_PARSER_MAX_PAGES=500
DOCUMENT_PARSER_MAX_ZIP_ENTRIES=5000
DOCUMENT_PARSER_MAX_UNCOMPRESSED_BYTES=104857600
OBJECT_DELETION_SCAN_INTERVAL=30s
OBJECT_DELETION_LEASE_DURATION=2m
OBJECT_DELETION_BATCH_SIZE=20
# Keep zero with the default disabled provider. Fake/local integration profiles set both
# values and seed the matching immutable fake price catalog version.
DOCUMENT_AI_ESTIMATED_COST_USD=0.000000
DOCUMENT_AI_PRICE_VERSION=0

# AI provider (P4 production default is network-disabled; enable only in a later provider phase)
AI_PROVIDER=none
AI_PROVIDER_API_KEY=
AI_CHAT_MODEL_PROVIDER=none
AI_EMBEDDING_MODEL_PROVIDER=none
AI_VECTOR_STORE_PROVIDER=none
AI_MODEL_LOW_COST=
AI_MODEL_BALANCED=gpt-5-mini
AI_MODEL_HIGH_QUALITY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_DAILY_BUDGET_USD=2.00
AI_RUN_MAX_COST_USD=0.30

# Durable Agent Run worker runtime
AGENT_HEARTBEAT_INTERVAL=15s
AGENT_LEASE_DURATION=60s
AGENT_RECONCILIATION_INTERVAL=30s
AGENT_DISPATCH_INTERVAL=1s
AGENT_WORKER_THREADS=2
AGENT_QUEUE_CAPACITY=32
AGENT_RECONCILIATION_BATCH_SIZE=50
AGENT_WORKER_ID=local-worker

# External search (optional until research features are implemented)
TAVILY_API_KEY=

# Frontend / local mail testing
FRONTEND_ORIGIN=http://localhost:5173
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Docker Compose - PostgreSQL
POSTGRES_DB=hiresemble
POSTGRES_USER=hiresemble
POSTGRES_PASSWORD=hiresemble-local-password
POSTGRES_PORT=5432

# Backend datasource (JDBC URL)
DATABASE_URL=jdbc:postgresql://localhost:5432/hiresemble
DATABASE_USERNAME=hiresemble
DATABASE_PASSWORD=hiresemble-local-password
BACKEND_PORT=8080
SESSION_COOKIE_SECURE=false

# Docker Compose - MinIO / S3-compatible object storage
MINIO_ROOT_USER=hiresemble
MINIO_ROOT_PASSWORD=hiresemble-local-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=hiresemble
OBJECT_STORAGE_SECRET_KEY=hiresemble-local-secret
OBJECT_STORAGE_BUCKET=hiresemble

# AI provider (optional until AI features are implemented)
AI_PROVIDER=openai
AI_PROVIDER_API_KEY=
AI_CHAT_MODEL_PROVIDER=none
AI_EMBEDDING_MODEL_PROVIDER=none
AI_VECTOR_STORE_PROVIDER=none
AI_MODEL_LOW_COST=
AI_MODEL_BALANCED=gpt-5-mini
AI_MODEL_HIGH_QUALITY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_DAILY_BUDGET_USD=2.00
AI_RUN_MAX_COST_USD=0.30

# External search (optional until research features are implemented)
TAVILY_API_KEY=

# Frontend / local mail testing
FRONTEND_ORIGIN=http://localhost:5173
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
